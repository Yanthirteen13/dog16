# Which AI provider to use for report generation: "anthropic" or "deepseek"
AI_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# Optional: override the DeepSeek API base URL
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Public base URL used for report links / QR codes
NEXT_PUBLIC_BASE_URL=http://localhost:3000
